<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="12" style="-fx-padding: 20;" xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.example.coursework.controllers.general.AddDishController">

    <Label text="Add New Dish" style="-fx-font-size: 16; -fx-font-weight: bold;"/>

    <GridPane hgap="10" vgap="8">
        <Label text="Name:" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
        <TextField fx:id="fieldName" GridPane.rowIndex="0" GridPane.columnIndex="1" prefWidth="220"/>

        <Label text="Description:" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
        <TextArea fx:id="fieldDescription" GridPane.rowIndex="1" GridPane.columnIndex="1"
                  prefWidth="220" prefHeight="80" wrapText="true"/>

        <Label text="Price (€):" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
        <TextField fx:id="fieldPrice" GridPane.rowIndex="2" GridPane.columnIndex="1"/>
    </GridPane>

    <Label fx:id="errorLabel" style="-fx-text-fill: red;"/>

    <HBox spacing="10">
        <Button text="Save" onAction="#handleSave"
                style="-fx-background-color: #4CAF50; -fx-text-fill: white;"/>
        <Button text="Cancel" onAction="#handleCancel"/>
    </HBox>
</VBox>