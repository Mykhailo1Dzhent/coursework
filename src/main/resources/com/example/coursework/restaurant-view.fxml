<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane prefHeight="700.0" prefWidth="1000.0"
            xmlns="http://javafx.com/javafx/25"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.coursework.controllers.RestaurantController">

    <top>
        <VBox style="-fx-background-color: #990000; -fx-padding: 15;">
            <Label style="-fx-text-fill: white; -fx-font-size: 20; -fx-font-weight: bold;" text="Restaurant Owner Panel" />
        </VBox>
    </top>

    <center>
        <TabPane fx:id="tabPane" tabClosingPolicy="UNAVAILABLE">

            <!-- INFO TAB -->
            <Tab text="Info">
                <VBox spacing="15" style="-fx-padding: 20;">
                    <Label text="Restaurant Information" style="-fx-font-size: 16; -fx-font-weight: bold;" />

                    <GridPane hgap="15" vgap="12">
                        <Label text="Restaurant Name:" GridPane.columnIndex="0" GridPane.rowIndex="0" style="-fx-font-weight: bold;" />
                        <TextField fx:id="infoName" promptText="Restaurant name" prefWidth="300" GridPane.columnIndex="1" GridPane.rowIndex="0" />

                        <Label text="Cuisine Type:" GridPane.columnIndex="0" GridPane.rowIndex="1" style="-fx-font-weight: bold;" />
                        <TextField fx:id="infoCuisine" promptText="e.g. Italian, Japanese" prefWidth="300" GridPane.columnIndex="1" GridPane.rowIndex="1" />

                        <Label text="Opening Time:" GridPane.columnIndex="0" GridPane.rowIndex="2" style="-fx-font-weight: bold;" />
                        <TextField fx:id="infoOpening" promptText="e.g. 09:00" prefWidth="300" GridPane.columnIndex="1" GridPane.rowIndex="2" />

                        <Label text="Closing Time:" GridPane.columnIndex="0" GridPane.rowIndex="3" style="-fx-font-weight: bold;" />
                        <TextField fx:id="infoClosing" promptText="e.g. 22:00" prefWidth="300" GridPane.columnIndex="1" GridPane.rowIndex="3" />
                    </GridPane>

                    <HBox spacing="10">
                        <Button text="Save Changes" onAction="#handleSaveInfo"
                                style="-fx-background-color: #27ae60; -fx-text-fill: white;" />
                        <Button text="Refresh" onAction="#handleRefreshInfo" />
                    </HBox>

                    <Label fx:id="infoMessage" textFill="green" />
                </VBox>
            </Tab>

            <!-- MENU ITEMS TAB -->
            <Tab text="Menu Items">
                <VBox spacing="10" style="-fx-padding: 15;">
                    <Label text="Menu" style="-fx-font-weight: bold; -fx-font-size: 14;" />
                    <TableView fx:id="dishesTable" VBox.vgrow="ALWAYS">
                        <columns>
                            <TableColumn fx:id="colDishId" prefWidth="50" text="ID" />
                            <TableColumn fx:id="colDishName" prefWidth="180" text="Name" />
                            <TableColumn fx:id="colDishDescription" prefWidth="300" text="Description" />
                            <TableColumn fx:id="colDishPrice" prefWidth="100" text="Price" />
                        </columns>
                    </TableView>
                    <HBox spacing="10">
                        <Button onAction="#handleAddDish" style="-fx-background-color: #27ae60; -fx-text-fill: white;" text="Add Dish" />
                        <Button onAction="#handleEditDish" style="-fx-background-color: #2980b9; -fx-text-fill: white;" text="Edit Dish" />
                        <Button onAction="#handleDeleteDish" style="-fx-background-color: #e74c3c; -fx-text-fill: white;" text="Delete Dish" />
                        <Button onAction="#handleRefreshDishes" text="Refresh" />
                    </HBox>
                </VBox>
            </Tab>

            <!-- ORDERS TAB -->
            <Tab text="Orders">
                <VBox spacing="10" style="-fx-padding: 15;">
                    <HBox alignment="CENTER_LEFT" spacing="10">
                        <ComboBox fx:id="filterOrderStatus" prefWidth="130" promptText="Status" />
                        <TextField fx:id="filterOrderCustomer" prefWidth="150" promptText="Customer" />
                        <DatePicker fx:id="filterOrderDate" prefWidth="150" promptText="Date" />
                        <Button onAction="#handleFilterOrders" text="Search" />
                        <Button onAction="#handleResetOrderFilter" text="Reset" />
                    </HBox>
                    <TableView fx:id="ordersTable" VBox.vgrow="ALWAYS">
                        <columns>
                            <TableColumn fx:id="colOrderId" prefWidth="50" text="ID" />
                            <TableColumn fx:id="colOrderCustomer" prefWidth="150" text="Customer" />
                            <TableColumn fx:id="colOrderDriver" prefWidth="120" text="Driver" />
                            <TableColumn fx:id="colOrderStatus" prefWidth="120" text="Status" />
                            <TableColumn fx:id="colOrderTime" prefWidth="150" text="Order Time" />
                            <TableColumn fx:id="colOrderPrice" prefWidth="100" text="Total Price" />
                        </columns>
                    </TableView>
                    <HBox spacing="10">
                        <Button onAction="#handleAcceptOrder" style="-fx-background-color: #27ae60; -fx-text-fill: white;" text="Accept Order" />
                        <Button onAction="#handleChangeStatus" style="-fx-background-color: #2980b9; -fx-text-fill: white;" text="Change Status" />
                        <Button onAction="#handleRefreshOrders" text="Refresh" />
                    </HBox>
                </VBox>
            </Tab>

            <!-- MESSAGES TAB -->
            <Tab text="Messages">
                <VBox spacing="10" style="-fx-padding: 15;">
                    <TabPane tabClosingPolicy="UNAVAILABLE" style="-fx-tab-min-height: 30;">

                        <!-- Order Messages -->
                        <Tab text="Order Messages">
                            <VBox spacing="10" style="-fx-padding: 10;">
                                <TableView fx:id="messagesTable" VBox.vgrow="ALWAYS">
                                    <columns>
                                        <TableColumn fx:id="colMessageId" prefWidth="50" text="ID" />
                                        <TableColumn fx:id="colMessageOrder" prefWidth="100" text="Order ID" />
                                        <TableColumn fx:id="colMessageSender" prefWidth="150" text="Sender" />
                                        <TableColumn fx:id="colMessageText" prefWidth="350" text="Message" />
                                        <TableColumn fx:id="colMessageTime" prefWidth="150" text="Time" />
                                    </columns>
                                </TableView>
                                <HBox spacing="10">
                                    <Button text="New Message" onAction="#handleNewMessage" style="-fx-background-color: #27ae60; -fx-text-fill: white;" />
                                    <Button text="Edit Message" onAction="#handleEditMessage" style="-fx-background-color: #2980b9; -fx-text-fill: white;" />
                                    <Button text="Delete Message" onAction="#handleDeleteMessage" style="-fx-background-color: #e74c3c; -fx-text-fill: white;" />
                                    <Button onAction="#handleRefreshMessages" text="Refresh" />
                                </HBox>
                            </VBox>
                        </Tab>

                        <!-- Admin Notifications -->
                        <Tab text="Admin Notifications">
                            <VBox spacing="10" style="-fx-padding: 10;">
                                <TableView fx:id="notificationsTable" VBox.vgrow="ALWAYS">
                                    <columns>
                                        <TableColumn fx:id="colNotifId" prefWidth="50" text="ID" />
                                        <TableColumn fx:id="colNotifTitle" prefWidth="180" text="Title" />
                                        <TableColumn fx:id="colNotifMessage" prefWidth="400" text="Message" />
                                        <TableColumn fx:id="colNotifTime" prefWidth="150" text="Time" />
                                        <TableColumn fx:id="colNotifRead" prefWidth="60" text="Read" />
                                    </columns>
                                </TableView>
                                <HBox spacing="10">
                                    <Button text="Mark as Read" onAction="#handleMarkAsRead" style="-fx-background-color: #27ae60; -fx-text-fill: white;" />
                                    <Button text="Refresh" onAction="#handleRefreshNotifications" />
                                </HBox>
                            </VBox>
                        </Tab>

                    </TabPane>
                </VBox>
            </Tab>

            <!-- STATISTICS TAB -->
            <Tab text="Statistics">
                <VBox alignment="TOP_LEFT" spacing="20" style="-fx-padding: 20;">
                    <Label style="-fx-font-weight: bold; -fx-font-size: 16;" text="Overview" />
                    <GridPane hgap="20" vgap="10">
                        <Label style="-fx-font-weight: bold;" text="Total Orders:" GridPane.columnIndex="0" GridPane.rowIndex="0" />
                        <Label fx:id="statTotalOrders" text="—" GridPane.columnIndex="1" GridPane.rowIndex="0" />

                        <Label text="Completed Orders:" GridPane.columnIndex="0" GridPane.rowIndex="1" />
                        <Label fx:id="statCompletedOrders" text="—" GridPane.columnIndex="1" GridPane.rowIndex="1" />

                        <Label text="Pending Orders:" GridPane.columnIndex="0" GridPane.rowIndex="2" />
                        <Label fx:id="statPendingOrders" text="—" GridPane.columnIndex="1" GridPane.rowIndex="2" />

                        <Label style="-fx-font-weight: bold;" text="Total Revenue:" GridPane.columnIndex="0" GridPane.rowIndex="3" />
                        <Label fx:id="statRevenue" text="—" GridPane.columnIndex="1" GridPane.rowIndex="3" />

                        <Label style="-fx-font-weight: bold;" text="Average Order Value:" GridPane.columnIndex="0" GridPane.rowIndex="4" />
                        <Label fx:id="statAvgOrder" text="—" GridPane.columnIndex="1" GridPane.rowIndex="4" />

                        <Label text="Total Menu Items:" GridPane.columnIndex="0" GridPane.rowIndex="5" />
                        <Label fx:id="statMenuItems" text="—" GridPane.columnIndex="1" GridPane.rowIndex="5" />

                        <Label text="Most Popular Dish:" GridPane.columnIndex="0" GridPane.rowIndex="6" />
                        <Label fx:id="statPopularDish" text="—" GridPane.columnIndex="1" GridPane.rowIndex="6" />
                    </GridPane>
                    <Button onAction="#handleRefreshStatistics" text="Refresh Statistics" />
                </VBox>
            </Tab>

        </TabPane>
    </center>

</BorderPane>
