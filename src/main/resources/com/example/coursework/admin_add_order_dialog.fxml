<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="12" style="-fx-padding: 20;" xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.example.coursework.controllers.admins.AdminAddOrderController">

    <Label text="New order" style="-fx-font-size: 16; -fx-font-weight: bold;"/>

    <Label text="Creates a row in orders (no line items). Use for testing or manual corrections."
           wrapText="true" style="-fx-text-fill: #555;"/>

    <GridPane hgap="10" vgap="8">
        <Label text="Customer:" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
        <ComboBox fx:id="comboCustomer" prefWidth="280" GridPane.rowIndex="0" GridPane.columnIndex="1"/>

        <Label text="Restaurant:" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
        <ComboBox fx:id="comboRestaurant" prefWidth="280" GridPane.rowIndex="1" GridPane.columnIndex="1"/>

        <Label text="Driver (optional):" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
        <ComboBox fx:id="comboDriver" prefWidth="280" GridPane.rowIndex="2" GridPane.columnIndex="1"/>

        <Label text="Status:" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
        <ComboBox fx:id="comboStatus" prefWidth="280" GridPane.rowIndex="3" GridPane.columnIndex="1"/>

        <Label text="Total price (€):" GridPane.rowIndex="4" GridPane.columnIndex="0"/>
        <TextField fx:id="fieldTotalPrice" promptText="e.g. 12.50" GridPane.rowIndex="4" GridPane.columnIndex="1"/>
    </GridPane>

    <Label fx:id="errorLabel" style="-fx-text-fill: red;"/>

    <HBox spacing="10">
        <Button text="Save" onAction="#handleSave" style="-fx-background-color: #27ae60; -fx-text-fill: white;"/>
        <Button text="Cancel" onAction="#handleCancel"/>
    </HBox>
</VBox>
