<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="12" style="-fx-padding: 20;" xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.example.coursework.controllers.restaurants.RestaurantEditMessageController">

    <Label text="Edit Message" style="-fx-font-size: 16; -fx-font-weight: bold;"/>

    <GridPane hgap="10" vgap="8">
        <Label text="Order ID:" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
        <Label fx:id="labelOrderId" GridPane.rowIndex="0" GridPane.columnIndex="1"
               style="-fx-font-weight: bold;"/>

        <Label text="Message:" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
        <TextArea fx:id="fieldMessage" GridPane.rowIndex="1" GridPane.columnIndex="1"
                  prefWidth="280" prefHeight="100" wrapText="true"/>
    </GridPane>

    <Label fx:id="errorLabel" style="-fx-text-fill: red;"/>

    <HBox spacing="10">
        <Button text="Save" onAction="#handleSave"
                style="-fx-background-color: #2980b9; -fx-text-fill: white;"/>
        <Button text="Cancel" onAction="#handleCancel"/>
    </HBox>
</VBox>
